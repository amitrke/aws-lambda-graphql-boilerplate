{
  "compilerOptions": {
    "target": "es2020",
    "module": "nodenext",
    "lib": [
      "dom", "es2020", "esnext"
    ],
    "moduleResolution": "nodenext",
    "typeRoots": [
      "./node_modules/@types"
    ],
    "types": [
      "node"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "sourceMap": false,
    "outDir": "lib",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules"
  ]
}
